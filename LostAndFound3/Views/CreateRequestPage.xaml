<Page x:Class="LostAndFound3.Views.CreateRequestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Title="CreateRequestPage">
    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Background" Value="#F8FAFD"/>
            <Setter Property="BorderBrush" Value="#D5DFED"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Background" Value="#F8FAFD"/>
            <Setter Property="BorderBrush" Value="#D5DFED"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Page.Resources>

    <Grid Margin="22">
        <Border Background="#F8FAFD" CornerRadius="20" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1" Width="520" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <Button Content="← Назад" Width="110" HorizontalAlignment="Left" Style="{StaticResource SecondaryButtonStyle}" Click="Back_Click"/>
                <TextBlock Text="Новая заявка" FontSize="28" FontWeight="SemiBold" Margin="0,10,0,10" Foreground="#0F172A"/>
                <TextBlock Text="Укажите название и описание потерянной вещи."
                           Foreground="#64748B"
                           Margin="0,0,0,20"/>

                <TextBox x:Name="NameBox"
                         Height="44"
                         Margin="0,0,0,12"
                         Text="Введите название вещи"
                         Foreground="Gray"
                         GotFocus="NameBox_GotFocus"
                         LostFocus="NameBox_LostFocus"/>

                <TextBox x:Name="DescriptionBox"
                         Height="120"
                         Margin="0,0,0,18"
                         Text="Введите описание вещи"
                         Foreground="Gray"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         GotFocus="DescriptionBox_GotFocus"
                         LostFocus="DescriptionBox_LostFocus"/>

                <Button Content="Оставить заявку"
                        Width="170"
                        HorizontalAlignment="Left"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
