<Page x:Class="LostAndFound3.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Title="LoginPage">
    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="Background" Value="#F8FAFD"/>
            <Setter Property="BorderBrush" Value="#D5DFED"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="Background" Value="#F8FAFD"/>
            <Setter Property="BorderBrush" Value="#D5DFED"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E3A8A"/>
            <Setter Property="Background" Value="#EEF4FF"/>
            <Setter Property="BorderBrush" Value="#D7E5FF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Page.Resources>

    <Grid Background="Transparent">
        <Border Background="White" Padding="44" CornerRadius="0,24,24,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Добро пожаловать" FontSize="30" FontWeight="SemiBold" Foreground="#0F172A"/>
                <TextBlock Text="Войдите в систему, чтобы продолжить работу."
                           Margin="0,10,0,28"
                           Foreground="#64748B"
                           FontSize="15"/>

                <TextBlock Text="Логин" Margin="0,0,0,6" Foreground="#334155" FontWeight="SemiBold"/>
                <TextBox x:Name="LoginBox"
                         Text="Введите логин"
                         Foreground="Gray"
                         GotFocus="LoginBox_GotFocus"
                         LostFocus="LoginBox_LostFocus"/>

                <TextBlock Text="Пароль" Margin="0,4,0,6" Foreground="#334155" FontWeight="SemiBold"/>
                <Grid Margin="0,0,0,12">
                    <PasswordBox x:Name="PsbPass"
                                 PasswordChanged="PsbPass_PasswordChanged"
                                 KeyDown="PsbPass_KeyDown"/>
                    <TextBlock x:Name="PasswordPlaceholder"
                               Text="Введите пароль"
                               Margin="12,-10,0,0"
                               VerticalAlignment="Center"
                               Foreground="Gray"
                               IsHitTestVisible="False"/>
                </Grid>

                <Button Content="Войти"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="LoginButton_Click"/>

                <Button Content="Регистрация"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="RegisterButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
