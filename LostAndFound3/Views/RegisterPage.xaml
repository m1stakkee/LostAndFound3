<Page x:Class="LostAndFound3.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Title="RegisterPage">
    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="Background" Value="#F8FAFD"/>
            <Setter Property="BorderBrush" Value="#D5DFED"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="Background" Value="#F8FAFD"/>
            <Setter Property="BorderBrush" Value="#D5DFED"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Background" Value="#EEF4FF"/>
            <Setter Property="Foreground" Value="#1E3A8A"/>
            <Setter Property="BorderBrush" Value="#D7E5FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <Grid Background="Transparent">
        <Border Background="White" Padding="36" CornerRadius="0,24,24,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Content="← Назад"
                        Style="{StaticResource BackButtonStyle}"
                        HorizontalAlignment="Left"
                        Click="Back_Click"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,18,0,0">
                        <TextBlock Text="Регистрация" FontSize="30" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="Создайте учётную запись пользователя."
                                   Margin="0,10,0,24"
                                   Foreground="#64748B"/>

                        <TextBox x:Name="LoginBox" 
                                 Text="Введите логин" 
                                 Foreground="Gray"
                                 GotFocus="LoginBox_GotFocus" 
                                 LostFocus="LoginBox_LostFocus"/>

                        <Grid Margin="0,0,0,10">
                            <PasswordBox x:Name="PasswordBox" PasswordChanged="PasswordBox_PasswordChanged"/>
                            <TextBlock x:Name="PasswordPlaceholder"
                                       Text="Введите пароль"
                                       Margin="15,8,0,0"
                                       VerticalAlignment="Top"
                                       Foreground="Gray"
                                       />
                        </Grid>

                        <TextBox x:Name="NameBox" Text="Введите имя" Foreground="Gray"
                                 GotFocus="NameBox_GotFocus" LostFocus="NameBox_LostFocus"/>
                        <TextBox x:Name="SurnameBox" Text="Введите фамилию" Foreground="Gray"
                                 GotFocus="SurnameBox_GotFocus" LostFocus="SurnameBox_LostFocus"/>
                        <TextBox x:Name="PhoneBox" Text="Введите телефон" Foreground="Gray"
                                 GotFocus="PhoneBox_GotFocus" LostFocus="PhoneBox_LostFocus"/>
                        <TextBox x:Name="EmailBox" Text="Введите почту" Foreground="Gray"
                                 GotFocus="EmailBox_GotFocus" LostFocus="EmailBox_LostFocus"/>

                        <Button Content="Зарегистрироваться"
                                Margin="0,8,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="RegisterButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
