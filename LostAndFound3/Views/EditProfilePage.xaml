<Page x:Class="LostAndFound3.Views.EditProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="EditProfilePage"
      Background="Transparent">

    <Grid Margin="20">
        <Border Background="White" CornerRadius="16" Padding="24">
            <StackPanel>
                <Button Content="← Назад"
                        Width="110"
                        Height="34"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,20"
                        Click="Back_Click"/>

                <TextBlock Text="Редактирование профиля"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Логин" Margin="0,0,0,6"/>
                <TextBox x:Name="LoginBox" Height="36" Margin="0,0,0,14"/>

                <TextBlock Text="Фамилия Имя" Margin="0,0,0,6"/>
                <TextBox x:Name="FullNameBox" Height="36" Margin="0,0,0,14"/>

                <TextBlock Text="Телефон" Margin="0,0,0,6"/>
                <TextBox x:Name="PhoneBox" Height="36" Margin="0,0,0,14"/>

                <TextBlock Text="Почта" Margin="0,0,0,6"/>
                <TextBox x:Name="EmailBox" Height="36" Margin="0,0,0,20"/>

                <Button Content="Сохранить"
                        Width="160"
                        Height="40"
                        Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
