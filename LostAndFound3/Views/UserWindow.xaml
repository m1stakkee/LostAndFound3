<Window x:Class="LostAndFound.Views.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь"
        Height="760"
        Width="1160"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FB">
    <Grid Margin="20">
        <Border Background="White" CornerRadius="24" BorderBrush="#E6ECF5" BorderThickness="1">
            <Frame x:Name="UserFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>
