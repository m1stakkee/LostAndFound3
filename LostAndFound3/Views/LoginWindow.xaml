<Window x:Class="LostAndFound.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход" Height="320" Width="300"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="200">

            <Frame x:Name="LoginFrame" 
                   NavigationUIVisibility="Hidden">
                
            </Frame>
            <TextBox x:Name="LoginBox"
                     Height="30"
                     Margin="0,5"
                     Text="Введите логин"
                     Foreground="Gray"
                     GotFocus="LoginBox_GotFocus"
                     LostFocus="LoginBox_LostFocus"/>

           
            <Grid>
                <PasswordBox x:Name="PsbPass"
                             Height="30"
                             Margin="0,5"
                             PasswordChanged="PsbPass_PasswordChanged"
                             KeyDown="PsbPass_KeyDown"/>

                <TextBlock x:Name="PasswordPlaceholder"
                           Text="Введите пароль"
                           Foreground="Gray"
                           Margin="5,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Grid>

            
            <Button Content="Войти"
                    Height="30"
                    Margin="0,10,0,0"
                    Click="LoginButton_Click"/>

            
            <Button Content="Регистрация"
                    Height="30"
                    Margin="0,5,0,0"
                    Click="RegisterButton_Click"/>

        </StackPanel>
    </Grid>
</Window>