<Window x:Class="LostAndFound3.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход"
        Height="560"
        Width="920"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FB"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <Style TargetType="Frame">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Border Background="White" CornerRadius="24" Padding="0" BorderBrush="#E6ECF5" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="1.35*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#2563EB" CornerRadius="24,0,0,24">
                    <Grid Margin="36">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Бюро находок" FontSize="34" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Современная система учёта и выдачи найденных вещей."
                                       Margin="0,14,0,0"
                                       TextWrapping="Wrap"
                                       FontSize="16"
                                       Foreground="#DCE8FF"/>
                            <Border Margin="0,28,0,0" Background="#3B82F6" CornerRadius="18" Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Что можно сделать" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Margin="0,10,0,0" Foreground="#EAF1FF" TextWrapping="Wrap">
• Войти как администратор или пользователь
• Искать найденные вещи
• Оставлять заявки и выдавать вещи
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Frame x:Name="LoginFrame" NavigationUIVisibility="Hidden"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
