<Window x:Class="LostAndFound.Views.GiveItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выдать вещь" Height="400" Width="300"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="10">

        <TextBlock Text="Выберите пользователя:" Margin="5"/>

        <DataGrid x:Name="UsersGrid"
                  AutoGenerateColumns="False"
                  Height="250"
                  Margin="5">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FullName}"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}"/>
                <DataGridTextColumn Header="Почта" Binding="{Binding Email}"/>
            </DataGrid.Columns>

        </DataGrid>

        <Button Content="Выдать"
                Margin="5"
                Height="30"
                Click="Give_Click"/>

    </StackPanel>
</Window>