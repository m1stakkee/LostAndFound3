<Window x:Class="LostAndFound.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="320" Width="300"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="200">

            
            <TextBox x:Name="LoginBox"
                     Height="30"
                     Margin="0,5"
                     Text="Введите логин"
                     Foreground="Gray"
                     GotFocus="LoginBox_GotFocus"
                     LostFocus="LoginBox_LostFocus"/>

            <Grid>
                <PasswordBox x:Name="PasswordBox"
                             Height="30"
                             Margin="0,5"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <TextBlock x:Name="PasswordPlaceholder"
                           Text="Введите пароль"
                           Foreground="Gray"
                           Margin="5,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Grid>

            
            <Button Content="Зарегистрироваться"
                    Height="30"
                    Margin="0,10,0,0"
                    Click="RegisterButton_Click"/>

        </StackPanel>
    </Grid>
</Window>