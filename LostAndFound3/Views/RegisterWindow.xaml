<Window x:Class="LostAndFound3.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="500" Width="300"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="220">

            
            <TextBox x:Name="LoginBox"
                     Height="30"
                     Margin="0,5"
                     Text="Введите логин"
                     Foreground="Gray"
                     GotFocus="LoginBox_GotFocus"
                     LostFocus="LoginBox_LostFocus"/>

            
            <Grid>
                <PasswordBox x:Name="PasswordBox"
                             Height="30"
                             Margin="0,5"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <TextBlock x:Name="PasswordPlaceholder"
                           Text="Введите пароль"
                           Foreground="Gray"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Grid>

            
            <TextBox x:Name="NameBox"
                     Height="30"
                     Margin="0,5"
                     Text="Введите имя"
                     Foreground="Gray"
                     GotFocus="NameBox_GotFocus"
                     LostFocus="NameBox_LostFocus"/>

            
            <TextBox x:Name="SurnameBox"
                     Height="30"
                     Margin="0,5"
                     Text="Введите фамилию"
                     Foreground="Gray"
                     GotFocus="SurnameBox_GotFocus"
                     LostFocus="SurnameBox_LostFocus"/>

            
            <TextBox x:Name="PhoneBox"
                     Height="30"
                     Margin="0,5"
                     Text="Введите телефон"
                     Foreground="Gray"
                     GotFocus="PhoneBox_GotFocus"
                     LostFocus="PhoneBox_LostFocus"/>

           
            <TextBox x:Name="EmailBox"
                     Height="30"
                     Margin="0,5"
                     Text="Введите почту"
                     Foreground="Gray"
                     GotFocus="EmailBox_GotFocus"
                     LostFocus="EmailBox_LostFocus"/>

            
            <Button Content="Зарегистрироваться"
                    Height="30"
                    Margin="0,10,0,0"
                    Click="RegisterButton_Click"/>

        </StackPanel>
    </Grid>
</Window>